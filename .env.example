RUN_IDS=run0123

# Full Nextcloud WebDAV endpoint, for example:
# https://cloud.example.com/remote.php/dav/files/username
NEXTCLOUD_URL=https://cloud.example.com/remote.php/dav/files/username
NEXTCLOUD_USERNAME=username
NEXTCLOUD_PASSWORD=app-password
NEXTCLOUD_RUN_ROOT=/remote/path/training_artifacts
NEXTCLOUD_DATA_ROOT=/remote/path/training_data
NEXTCLOUD_MODEL_ROOT=/remote/path/models

WANDB_API_KEY=replace-me
WANDB_PROJECT=my-training-project
WANDB_ENTITY=
HF_TOKEN=

# Expose all GPUs by default. Set to a comma-separated selection such as 0.
CUDA_VISIBLE_DEVICES=all

# Local single-machine tuning. These are intentionally not baked into the image.
FORCE_TORCHRUN=0
USE_RAY=0
UNSLOTH_CE_LOSS_TARGET_GB=1
PYTORCH_ALLOC_CONF=garbage_collection_threshold:0.85

# Local runs should not call RunPod. On RunPod, omit this to default to "stop",
# or set "terminate" to delete the Pod after checkpoint upload.
RUNPOD_SHUTDOWN_ACTION=none
